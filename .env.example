# Video Composer - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---

# Anthropic API key (for Claude Vision descriptions + AI Director)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (database + storage)
SUPABASE_URL=https://wuevigbacntyssfreggh.supabase.co
SUPABASE_ANON_KEY=
# Service role key is needed for storage uploads and admin operations
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional ---

# Twelve Labs Embed API (preferred embedding engine; falls back to CLIP if unset)
# TWELVELABS_API_KEY=

# Jamendo API (royalty-free music library)
# Sign up (free) at: https://devportal.jamendo.com/signup
# Then create an app at: https://devportal.jamendo.com/admin/applications
# Your client_id will appear on the application page.
# Free tier: 35,000 API requests/month, non-commercial use.
# For commercial use, contact licensing@jamendo.com
# JAMENDO_CLIENT_ID=
